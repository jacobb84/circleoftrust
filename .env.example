MERCURE_PUBLISHER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
MERCURE_SUBSCRIBER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
# Frontend URLs (what the browser sees)
VITE_API_URL=http://localhost:8000
VITE_MERCURE_URL=http://localhost:3000/.well-known/mercure

# Backend Internal URL (how backend reaches Mercure inside Docker network)
MERCURE_URL=http://mercure:80/.well-known/mercure

# CORS origins for Backend API and Mercure (space-separated)
CORS_ORIGINS=http://localhost:5173 http://localhost:3000
